# FansFund Ops Dashboard — engine configuration.
#
# Copy this file to `.env` and fill in real values, OR export these variables
# in your shell before running `make deploy`. The deploy reads them (real shell
# environment takes precedence over .env) and injects them into the engine pod
# via a Kubernetes Secret generated at deploy time. `.env` is gitignored — never
# commit real credentials.
#
# Values may be quoted. Lines starting with # are ignored.

# --- Required ---------------------------------------------------------------
# Stripe secret API key.
STRIPE_API_KEY=

# MongoDB connection string (may embed the database name).
MONGODB_URI=

# AWS credentials + region for the dispute-evidence S3 bucket.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# Grafana HTTP API access + the Prometheus datasource to query.
GRAFANA_URL=
GRAFANA_API_KEY=
GRAFANA_DATASOURCE_UID=
# Comma-separated Prometheus job names to report health for, e.g. "api,worker".
GRAFANA_SERVICES=

# --- Optional ---------------------------------------------------------------
# Database name (only if not encoded in MONGODB_URI).
# MONGODB_DB=

# Overrides the default dispute-docs bucket (fans-fund-me-core-dispute-docs).
# S3_DISPUTE_DOCS_BUCKET=

# IAM role to assume (via STS AssumeRole) before accessing S3. When set, the
# credentials above are used only to assume this role; the resulting temporary
# credentials access the bucket. Leave unset to use the credentials directly.
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/fansfund-dispute-docs-reader
# AWS_ROLE_SESSION_NAME=fansfund-ops-dashboard
# External ID, only if the target role's trust policy requires one (cross-account).
# AWS_ROLE_EXTERNAL_ID=

# Auto-refresh interval in minutes (clamped to 1-60; defaults to 5).
# REFRESH_INTERVAL_MINUTES=5

# Per-source fetch timeout in milliseconds (default 10000). Raise this for
# high-volume Stripe accounts where paginating a month of charges takes >10s.
# SOURCE_TIMEOUT_MS=60000
